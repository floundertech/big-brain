# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional ---
# Enables web_search tool in chat. Get a key at https://tavily.com
# TAVILY_API_KEY=tvly-...

# --- Database ---
# Change this before exposing to your network
POSTGRES_PASSWORD=changeme

# --- Frontend ---
# Set to your server's LAN IP for access from phone/other devices
# Must rebuild frontend after changing: docker compose up -d --build frontend
# VITE_API_URL=http://192.168.1.x:8000

# --- Embeddings ---
# Override the local embedding model (default works well, no need to change)
# EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5
