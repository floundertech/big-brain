# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Optional ---
# Enables web_search tool in chat. Get a key at https://tavily.com
# TAVILY_API_KEY=tvly-...

# --- Database ---
# Change this before exposing to your network
POSTGRES_PASSWORD=changeme

# --- Frontend ---
# Set to your server's LAN IP for access from phone/other devices
# Must rebuild frontend after changing: docker compose up -d --build frontend
# VITE_API_URL=http://192.168.1.x:8000

# --- Embeddings ---
# Override the local embedding model (default works well, no need to change)
# EMBED_MODEL=nomic-ai/nomic-embed-text-v1.5

# --- RSS / Miniflux ---
# Both must be set to enable RSS ingestion. Leave unset to disable (app works fine without them).
# Use host.docker.internal (Mac) or the host IP — NOT localhost (backend runs inside a container).
# MINIFLUX_URL=http://host.docker.internal:8070
# MINIFLUX_API_KEY=<generated-in-miniflux-settings>
# RSS_POLL_INTERVAL_SECONDS=3600
# RSS_DIGEST_HOUR=5
# RSS_RELEVANCE_TOPICS=Dynatrace,ActiveGate,Grail,OneAgent,CVE,zero-day,vulnerability
# RSS_INITIAL_BACKFILL_DAYS=30

# --- Observability (Dynatrace + OpenLLMetry) ---
# Both must be set to enable LLM tracing. Leave unset to disable (app works fine without them).
# Token needs scopes: openTelemetryTrace.ingest, metrics.ingest, logs.ingest
# DT_OTLP_ENDPOINT=https://{your-env-id}.live.dynatrace.com/api/v2/otlp
# DT_API_TOKEN=dt0c01....
